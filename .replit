modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "pipeline: IL Extraction"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "pipeline: IL CBA Crawl"

[[workflows.workflow]]
name = "pipeline: IL Extraction"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd /home/runner/workspace/pipeline && python3 -u 06_extract_contracts.py --state IL; python3 -u 06_extract_contracts.py --state OH; echo \"[EXTRACTION DONE]\"; sleep infinity'"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "pipeline: IL CBA Crawl"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'cd /home/runner/workspace/pipeline && python3 -u 11_crawl_il_cbas.py; echo \"[CRAWL DONE]\"; sleep infinity'"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 18627
externalPort = 3000

[[ports]]
localPort = 19999
externalPort = 3001

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "postgresql", "rapidfuzz-cpp", "taskflow", "tesseract"]

[userenv]

[userenv.shared]
